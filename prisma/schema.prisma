generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("owner") // owner | manager | support
  createdAt    DateTime @default(now())
}

model Customer {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  address      String?
  city         String?
  province     String?
  postalCode   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
  reviews      Review[]
}

model Review {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  rating      Int      @default(5)
  title       String
  content     String
  status      String   @default("pending") // pending | published | rejected
  productId   String @db.ObjectId
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId  String @db.ObjectId
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AbandonedCart {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  email       String
  cartData    String   // JSON string of their cart items
  status      String   @default("abandoned") // abandoned | recovered
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String    @unique
  image       String?
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

// Marketing collections e.g. "Beauty Essentials Sale", "The Best Offers", "New Goods"
model Collection {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  slug      String              @unique
  color     String              @default("#1f6fdb")
  isActive  Boolean             @default(true)
  sortOrder Int                 @default(0)
  createdAt DateTime            @default(now())
  products  ProductCollection[]
  banners   Banner[]
}

model Product {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  slug            String              @unique
  description     String              @default("")
  price           Float
  comparePrice    Float?
  costPrice       Float?
  price2          Float?
  price3          Float?
  sku             String?
  stock           Int                 @default(0)
  images          String              @default("[]") // JSON array of URLs
  categoryId      String? @db.ObjectId
  category        Category?           @relation(fields: [categoryId], references: [id])
  collections     ProductCollection[]
  status          String              @default("active") // active | draft | archived
  isFeatured      Boolean             @default(false)
  rating          Float               @default(4.5)
  reviewsCount    Int                 @default(0)
  hasVariants     Boolean             @default(false) // New
  options         String?             // New: JSON array of options e.g. [{"name":"Size", "values":["S","M"]}]
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  orderItems      OrderItem[]
  reviews         Review[]
  variants        ProductVariant[]    // New
  celebrities     CelebrityRecommendation[]
  banners         Banner[]
}

model ProductVariant {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  productId       String @db.ObjectId
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku             String?
  price           Float
  comparePrice    Float?
  price2          Float?
  price3          Float?
  stock           Int      @default(0)
  optionChoices   String   // JSON object e.g. {"Size": "M", "Color": "Red"}
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Coupon {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  code            String   @unique
  type            String   // "percentage" | "fixed"
  value           Float    // 20 for 20% or 500 for $500
  minSpend        Float?
  usageLimit      Int?
  usageCount      Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProductCollection {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  productId    String @db.ObjectId
  collectionId String @db.ObjectId
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([productId, collectionId])
}

model Banner {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  subtitle    String?
  eyebrow     String?
  image       String
  mobileImage String?
  link        String    @default("#")
  position    String    @default("hero") // hero | promo | strip | sale
  bgColorFrom String    @default("#0f2542")
  bgColorTo   String    @default("#173963")
  textColor   String    @default("#ffffff")
  buttonText  String    @default("Shop Now")
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  alignLeft   Boolean   @default(false)
  imageFit    String    @default("cover")
  collectionId String? @db.ObjectId
  collection   Collection? @relation(fields: [collectionId], references: [id])
  productId   String? @db.ObjectId
  product     Product? @relation(fields: [productId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Article {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String    @unique
  content     String    // HTML or Markdown
  excerpt     String?
  image       String?
  category    String    @default("Blog")
  author      String    @default("BuySial")
  published   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Order {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber     String      @unique
  customerId      String? @db.ObjectId
  customer        Customer?   @relation(fields: [customerId], references: [id])
  customerName    String
  phone           String
  email           String?
  address         String
  city            String
  province        String?
  postalCode      String?
  notes           String?
  items           OrderItem[]
  subtotal        Float
  shippingFee     Float       @default(0)
  discount        Float       @default(0)
  total           Float
  paymentMethod   String      @default("cod") // cod | jazzcash | easypaisa | payfast | bank
  paymentStatus   String      @default("pending") // pending | paid | failed | refunded
  paymentRef      String?
  orderStatus     String      @default("processing") // processing | confirmed | packed | shipped | delivered | cancelled | returned
  courierProvider String?     // leopards | tcs | postex | mnp | trax
  trackingNumber  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String @db.ObjectId
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String? @db.ObjectId
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  image     String?
  price     Float
  qty       Int
}

// Singleton-style key/value settings store (JSON-stringified values)
model Setting {
  key   String @id @map("_id")
  value String
}

model CelebrityRecommendation {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  image       String?
  videoUrl    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  productId   String? @db.ObjectId
  product     Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
